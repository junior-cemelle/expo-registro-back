# ── Supabase ─────────────────────────────────────────────────
# Obtén estos valores en: Supabase Dashboard → Settings → API

# URL del proyecto (ej: https://xyzxyz.supabase.co)
SUPABASE_URL="https://[PROJECT-REF].supabase.co"

# Clave de servicio — acceso total, nunca expongas en frontend
# Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET="cambia-esto-por-una-cadena-larga-y-aleatoria-minimo-32-chars"
JWT_EXPIRES_IN="86400"

# ── Servidor ─────────────────────────────────────────────────
PORT=8080

# ── CORS ─────────────────────────────────────────────────────
# URL del frontend (Vercel en prod, localhost en dev)
FRONTEND_URL="http://localhost:3000"
